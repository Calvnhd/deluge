# Copy this file to .env and adjust paths for your machine

# Source: SAMPLES folder in this repo
SAMPLES_SOURCE="$HOME/source/deluge/DELUGE/SAMPLES/"

# Destination: Cloud-synced backup folder for SAMPLES
#   e.g OneDrive via WSL: /mnt/c/Users/YourName/OneDrive/Deluge-Backup/SAMPLES/
SAMPLES_BACKUP="/mnt/c/your/backup/path/"

# Path to mounted Deluge SD card
SD_CARD_PATH="/media/$USER/DELUGE"

# Destination for zip backups 
ZIP_BACKUP_PATH="/mnt/c/Users/YourName/OneDrive/Deluge-Backup/"
