# Sync configuration
# Copy this file to .env and adjust paths for your machine

# Source: SAMPLES folder in this repo
SAMPLES_SOURCE="$HOME/source/deluge/DELUGE/SAMPLES/"

# Destination: Cloud-synced backup folder
# Examples:
#   OneDrive: /mnt/c/Users/YourName/OneDrive/Deluge-Backup/SAMPLES/
#   Google Drive: /mnt/c/Users/YourName/Google Drive/Deluge-Backup/SAMPLES/
SAMPLES_BACKUP="/mnt/c/your/backup/path/"

# SD card backup configuration (for sd-to-zip.sh)
# Path to mounted Deluge SD card
# Examples:
#   Linux: /media/$USER/DELUGE
#   WSL:   /mnt/d (if D: is the SD card)
SD_CARD_PATH="/media/$USER/DELUGE"

# Destination for zip backups (cloud-synced folder recommended)
ZIP_BACKUP_PATH="/mnt/c/Users/YourName/OneDrive/Deluge-Backup/"
